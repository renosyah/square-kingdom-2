[gd_scene load_steps=2 format=2]

[ext_resource path="res://menus/gameplay/host/host.gd" type="Script" id=1]

[node name="gameplay" type="Node"]
script = ExtResource( 1 )

[node name="bot_harasment_spawner_timer" type="Timer" parent="."]
wait_time = 15.0
one_shot = true

[node name="bot_action_timer" type="Timer" parent="."]
wait_time = 5.0
one_shot = true

[connection signal="timeout" from="bot_harasment_spawner_timer" to="." method="_on_bot_spawner_timer_timeout"]
[connection signal="timeout" from="bot_action_timer" to="." method="_on_bot_action_timer_timeout"]
